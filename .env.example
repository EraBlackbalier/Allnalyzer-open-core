# Allnalyzer - configuracion local

# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=change-this-local-secret

# PostgreSQL local (Issue #2)
# Crea la base de datos con nombre: Allnalyzer
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=Allnalyzer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_ECHO=false

# Alternativa: si prefieres una URL completa, descomenta y ajusta.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/Allnalyzer

# LLM / IA
LLM_BACKEND=deepsek
DEEPSEK_API_URL=http://localhost:8080/v1/generate
DEEPSEK_API_KEY=your-deepsek-api-key
# OPENAI_API_KEY=sk-your-openai-api-key

# Storage local
RAW_STORAGE_FOLDER=storage/raw
PARQUET_STORAGE_FOLDER=storage/parquet

# Validacion y performance
MAX_FILE_SIZE_MB=100
MAX_ROWS_FOR_ANALYSIS=1000000

# Logging
LOG_LEVEL=INFO
LOG_FILE=allnalyzer.log
